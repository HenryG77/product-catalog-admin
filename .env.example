# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/product-catalog?schema=public"

# Authentication Secrets
# CRITICAL SECURITY: These secrets must be strong and unique in production!
#
# Generate secure secrets with one of these commands:
#   Option 1 (Base64 - Recommended): node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#   Option 2 (Hex):                  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
# IMPORTANT: Changing JWT_SECRET will invalidate all existing user sessions.
#            Users will need to login again.
#
# JWT_SECRET: Main secret for signing JWT tokens (REQUIRED, minimum 64 characters)
JWT_SECRET=YOUR_VERY_LONG_AND_SECURE_SECRET_HERE_MIN_64_CHARS
#
# JWT_SECRET_OLD: Previous JWT secret for rotation (OPTIONAL)
# Set this when rotating secrets to allow old tokens to still be valid temporarily
# JWT_SECRET_OLD=your_old_secret_here
#
# JWT token expiration time (default: 7 days)
JWT_EXPIRES_IN="7d"
#
# NextAuth secret (if using NextAuth in the future)
NEXTAUTH_SECRET=GENERATE_RANDOM_STRING_HERE
#
# Inactivity timeout in minutes (default: 30)
# Users will be logged out after this period of inactivity
INACTIVITY_TIMEOUT_MINUTES="30"

# Application URL
NEXTAUTH_URL=http://localhost:3001
