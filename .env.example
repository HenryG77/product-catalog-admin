# Database Configuration
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/product-catalog?schema=public"

# Authentication Secrets
# IMPORTANT: Generate cryptographically secure secrets for production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
NEXTAUTH_SECRET=GENERATE_RANDOM_STRING_HERE
JWT_SECRET=GENERATE_RANDOM_64_CHAR_STRING_HERE
JWT_EXPIRES_IN="7d"

# Application URL
NEXTAUTH_URL=http://localhost:3001
