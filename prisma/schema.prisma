generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String
  role               String   @default("admin")
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now()) @db.Timestamp(6)
  updatedAt          DateTime @updatedAt @db.Timestamp(6)

  @@index([email])
  @@index([role])
}

model banners {
  id              String      @id
  image           String
  title           String?
  description     String?
  link            String?
  whatsappMessage String?     @map("whatsapp_message")
  isActive        Boolean     @default(true) @map("is_active")
  order           Int         @default(0)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @map("updated_at")
  storeId         String      @map("store_id")
  categoryId      String?     @map("category_id")
  category        categories? @relation(fields: [categoryId], references: [id])
  store           stores      @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model categories {
  id          String     @id
  name        String
  description String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  storeId     String
  banners     banners[]
  stores      stores     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    products[]

  @@unique([storeId, name])
}

model product_images {
  id         String   @id
  url        String
  order      Int      @default(0)
  created_at DateTime @default(now())
  product_id String
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
}

model products {
  id              String           @id
  name            String
  description     String
  price           Float
  image           String
  whatsappMessage String
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime
  storeId         String
  categoryId      String
  currency        String           @default("PYG")
  lastUnits       Int?
  product_images  product_images[]
  categories      categories       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  stores          stores           @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model stores {
  id               String       @id
  name             String
  logo             String
  whatsapp         String
  primaryColor     String       @default("#3b82f6")
  secondaryColor   String       @default("#1e40af")
  description      String
  email            String?
  address          String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  footer_copyright String       @default("© 2024 Todos los derechos reservados")
  show_facebook    Boolean      @default(false)
  facebook_url     String?
  show_instagram   Boolean      @default(false)
  instagram_url    String?
  show_tiktok      Boolean      @default(false)
  tiktok_url       String?
  show_address     Boolean      @default(false)
  address_text     String?
  show_phone       Boolean      @default(false)
  phone_text       String?
  show_email       Boolean      @default(false)
  email_text       String?
  show_hours       Boolean      @default(false)
  hours_text       String?
  banners          banners[]
  categories       categories[]
  products         products[]
}
